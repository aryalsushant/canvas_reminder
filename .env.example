# Canvas LMS
CANVAS_API_URL=https://myschool.instructure.com
CANVAS_API_TOKEN=your_canvas_personal_access_token_here

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Reminder behaviour (optional — defaults shown)
REMINDER_HOURS_BEFORE=3
CHECK_INTERVAL_MINUTES=30
# Your local timezone (from the IANA tz database, e.g. America/New_York, Asia/Kathmandu)
TIMEZONE=UTC

# Comma-separated Canvas course IDs to monitor (optional).
# Leave empty to automatically monitor all active courses.
# Example: CANVAS_COURSE_IDS=12345,67890
CANVAS_COURSE_IDS=
